---
interface Props {
  items: { name: string; url: string }[];
}

const { items } = Astro.props;
---

<nav class="breadcrumbs" aria-label="Fil d'Ariane">
  <ol>
    <li><a href="/">Accueil</a></li>
    {items.map((item) => (
      <li>
        {item.url ? <a href={item.url}>{item.name}</a> : <span aria-current="page">{item.name}</span>}
      </li>
    ))}
  </ol>
</nav>
