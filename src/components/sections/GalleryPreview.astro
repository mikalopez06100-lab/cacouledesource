---
import type { CollectionEntry } from 'astro:content';
import SectionHeader from '../ui/SectionHeader.astro';
import ChantierGrid from '../chantiers/ChantierGrid.astro';
import { site } from '../../config/site';
import Icon from '../ui/Icon.astro';

interface Props {
  chantiers: CollectionEntry<'chantiers'>[];
}

const { chantiers } = Astro.props;
---

<section class="gallery" id="galerie">
  <div class="container">
    <SectionHeader
      eyebrow="Réalisations"
      title="Des chantiers que je suis fier de partager."
      description="Quelques rénovations récentes pour vous donner une idée de ce qu'on peut faire ensemble."
    />
    <ChantierGrid chantiers={chantiers} />
    <div class="gallery-cta">
      <a href="/realisations" class="btn-secondary">
        Voir toutes les réalisations
        <Icon name="arrow" size={18} />
      </a>
      <a
        href={site.social.instagram}
        class="btn-secondary"
        style="margin-left: 12px"
        target="_blank"
        rel="noopener noreferrer"
      >
        Instagram
        <Icon name="arrow" size={18} />
      </a>
    </div>
  </div>
</section>
