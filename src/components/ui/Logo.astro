---
import { site } from '../../config/site';

interface Props {
  variant?: 'header' | 'footer';
}

const { variant = 'header' } = Astro.props;
const isFooter = variant === 'footer';
const webp = isFooter ? '/images/logo-footer.webp' : site.logoWebp;
const fallback = site.logo;
const width = isFooter ? 320 : 240;
const height = isFooter ? 94 : 70;
---

<a
  href="/"
  class:list={['logo-brand', isFooter && 'logo-brand--footer']}
  aria-label={`${site.name} — ${site.owner}, plombier à La Garde (Var), retour à l'accueil`}
>
  <picture>
    <source srcset={webp} type="image/webp" />
    <img
      src={fallback}
      alt={`${site.name} — ${site.owner}, plombier Var`}
      width={width}
      height={height}
      loading={isFooter ? 'lazy' : 'eager'}
      decoding="async"
    />
  </picture>
</a>
