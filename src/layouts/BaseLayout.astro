---
import '../styles/global.css';
import '../styles/components.css';
import SEOHead from '../components/seo/SEOHead.astro';

interface Props {
  title: string;
  description: string;
  path?: string;
  ogImage?: string;
  ogImageAlt?: string;
  noindex?: boolean;
}

const { title, description, path, ogImage, ogImageAlt, noindex } = Astro.props;
---

<!doctype html>
<html lang="fr">
  <head>
    <SEOHead
      title={title}
      description={description}
      path={path}
      ogImage={ogImage}
      ogImageAlt={ogImageAlt}
      noindex={noindex}
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <slot name="head" />
  </head>
  <body>
    <a href="#main-content" class="skip-link">Aller au contenu principal</a>
    <slot />
    <!-- Widget Netlify Identity — actif uniquement en production Netlify -->
    <script is:inline src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
  </body>
</html>
