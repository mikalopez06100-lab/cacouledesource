---
import PageLayout from '../layouts/PageLayout.astro';
import Hero from '../components/sections/Hero.astro';
import Presentation from '../components/sections/Presentation.astro';
import ServicesGrid from '../components/sections/ServicesGrid.astro';
import GalleryPreview from '../components/sections/GalleryPreview.astro';
import Testimonials from '../components/sections/Testimonials.astro';
import ZoneIntervention from '../components/sections/ZoneIntervention.astro';
import FAQ from '../components/sections/FAQ.astro';
import ContactSection from '../components/sections/ContactSection.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import { localBusinessJsonLd } from '../components/seo/schemas/localBusiness';
import { faqPageJsonLd } from '../utils/seo';
import { faqGeneral, pageMeta } from '../config/site';
import { getCollection } from 'astro:content';

const chantiers = (await getCollection('chantiers'))
  .filter((c) => c.data.miseEnAvant)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

const meta = pageMeta.home;
---

<PageLayout title={meta.title} description={meta.description}>
  <JsonLd slot="head" data={[localBusinessJsonLd(), faqPageJsonLd(faqGeneral)]} />

  <Hero />
  <Presentation />
  <ServicesGrid />
  <GalleryPreview chantiers={chantiers} />
  <Testimonials />
  <ZoneIntervention />
  <FAQ items={faqGeneral} />
  <ContactSection />
</PageLayout>
